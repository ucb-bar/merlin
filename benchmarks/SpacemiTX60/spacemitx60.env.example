# Copy to spacemitx60.env and edit values for your board.

# Required:
REMOTE_HOST=192.168.1.50
REMOTE_USER=root

# Optional:
REMOTE_PORT=22
REMOTE_DIR=/tmp/merlin_dual_model_async
SSH_KEY=
# Example: SSH_EXTRA_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
SSH_EXTRA_OPTS=

# Local directory where logs/results will be stored.
LOCAL_RESULTS_DIR=
