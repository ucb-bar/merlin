graph LR
    subgraph old["Old CUDA HAL (~1ms/dispatch)"]
        direction LR
        A1[VM Bytecode] --> B1[Deferred<br/>Command Buffer]
        B1 --> C1[Queue<br/>Emulation]
        C1 --> D1[Stream<br/>Synchronization]
        D1 --> E1[cuLaunchKernel]

        B1 -.- F1["Enables CUDA<br/>graph capture"]
        C1 -.- G1["Multi-queue<br/>scheduling"]
    end

    subgraph new["New CUDA HAL (~0.06ms/dispatch)"]
        direction LR
        A2[VM Bytecode] --> E2[cuLaunchKernel]
        A2 --> H2[Event<br/>Synchronization]

        E2 -.- I2["Single stream,<br/>direct launch"]
    end

    style old fill:#fef3e2,stroke:#e67e22,stroke-width:2px
    style new fill:#e8f8e8,stroke:#27ae60,stroke-width:2px
    style F1 fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
    style G1 fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
    style I2 fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
