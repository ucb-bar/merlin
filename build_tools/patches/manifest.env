# Merlin patch manifest (sourced by CI scripts)
# shellcheck shell=bash
#
# This file pins the upstream IREE commit that ucb-bar/main is rebased onto.
# CI uses this to verify the rebase is clean:
#   git merge-base --is-ancestor $IREE_UPSTREAM_BASE <submodule HEAD>

# Upstream IREE repo and the commit our ucb-bar/main branch is based on.
IREE_UPSTREAM_REPO="https://github.com/iree-org/iree"
IREE_UPSTREAM_BASE="56acf7ed012bd0432802891cbc8e3f30ae5deb4e"

# Our fork where ucb-bar/main lives (submodule points here).
IREE_FORK_REPO="https://github.com/ucb-bar/iree"
IREE_FORK_BRANCH="ucb-bar/main"

# LLVM upstream base (nested inside iree_bar).
LLVM_UPSTREAM_BASE="1839675d168e357c3db1559446031d55833f0181"
