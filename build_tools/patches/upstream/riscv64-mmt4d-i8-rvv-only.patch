         iree_uk_query_matmul_tile_sizes_riscv_64_f32f32f32(params);
     return true;
-  } else {
+  } else if (op == IREE_UK_FLAG_QUERY_TILE_SIZES_OPERATION_MATMUL_I8I8I32) {
+    *out_matmul_tile_sizes =
+        iree_uk_query_matmul_tile_sizes_riscv_64_i8i8i32(params);
