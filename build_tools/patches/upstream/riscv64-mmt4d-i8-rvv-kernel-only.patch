+IREE_UK_ATTRIBUTE_ALWAYS_INLINE static inline void
+iree_uk_mmt4d_tile_s8s8s32_4x4x8_riscv_64_xsmtvdot_native(
+    iree_uk_int32_t* IREE_UK_RESTRICT out_ptr,
+    const iree_uk_int8_t* IREE_UK_RESTRICT lhs_ptr,
+    const iree_uk_int8_t* IREE_UK_RESTRICT rhs_ptr,
+    const iree_uk_mmt4d_params_t* params) {
+  IREE_UK_ASSERT(params->N0 == 4);
+  IREE_UK_ASSERT(params->K0 == 8);
+
+  if (params->flags & IREE_UK_FLAG_MMT4D_ACCUMULATE) {
+    asm volatile(
+        "vsetvli zero, zero, e32, m2, ta, ma\n\t"
+        "vle32.v v28, (%0)\n\t"
+        :
+        : "r"(out_ptr)
+        : "memory");
+  } else {
+    asm volatile(
+        "vsetvli zero, zero, e32, m2, ta, ma\n\t"
+        "vmv.v.i v28, 0\n\t"
+        :
+        :
+        : "memory");
+  }
+
+  asm volatile("vsetvli zero, zero, e8, m1, ta, ma\n\t" : : : "memory");
+  for (int k = 0; k < params->K; ++k) {
+    const iree_uk_int8_t* lhs_k_ptr = lhs_ptr + k * 32;
+    const iree_uk_int8_t* rhs_k_ptr = rhs_ptr + k * 32;
+    asm volatile(
+        "vle8.v v0, (%0)\n\t"
+        "vle8.v v1, (%1)\n\t"
+        ".insn r 0x2b, 0x3, 0x71, x28, x0, x1\n\t"
+        :
+        : "r"(lhs_k_ptr), "r"(rhs_k_ptr)
+        : "memory");
+  }
+
+  asm volatile(
+      "vsetvli zero, zero, e32, m2, ta, ma\n\t"
+      "vse32.v v28, (%0)\n\t"
+      :
+      : "r"(out_ptr)
+      : "memory");
+}
