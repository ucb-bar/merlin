+      vint8m1_t rhs = __riscv_vle8_v_i8m1(rhs_ptr, vl);
+      rhs_ptr += N0;
+      iree_uk_int8_t lhs = *lhs_ptr++;
+      IREE_UK_RISCV_64_VWACC_I8(acc0, lhs, rhs, vl);
+    }
+    __riscv_vse32_v_i32m4(out_ptr, acc0, vl);
