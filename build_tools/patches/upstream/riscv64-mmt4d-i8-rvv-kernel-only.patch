+      acc5 = __riscv_vle32_v_i32m4(out_ptr + N0 * 5, vl);
+      acc6 = __riscv_vle32_v_i32m4(out_ptr + N0 * 6, vl);
+      acc7 = __riscv_vle32_v_i32m4(out_ptr + N0 * 7, vl);
