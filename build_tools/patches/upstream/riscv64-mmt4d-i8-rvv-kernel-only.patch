+    __riscv_vse32_v_i32m4(out_ptr + N0 * 5, acc5, vl);
+    __riscv_vse32_v_i32m4(out_ptr + N0 * 6, acc6, vl);
+  } else if (M0 == 8) {
+    if (params->flags & IREE_UK_FLAG_MMT4D_ACCUMULATE) {
