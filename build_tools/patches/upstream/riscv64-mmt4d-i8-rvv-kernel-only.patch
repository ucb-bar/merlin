+      vint8m1_t rhs = __riscv_vle8_v_i8m1(rhs_ptr, vl);
+      rhs_ptr += N0;
+      iree_uk_int8_t lhs0 = *lhs_ptr++;
+      iree_uk_int8_t lhs1 = *lhs_ptr++;
